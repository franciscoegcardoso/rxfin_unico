{
  "name": "rxfin",
  "version": "1.0.0",
  "private": true,
  "description": "RXFin - Plataforma de finanças pessoais",
  "workspaces": [
    "apps/web",
    "apps/landing",
    "apps/mobile",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "turbo run dev --filter=web",
    "dev:landing": "turbo run dev --filter=landing",
    "dev:mobile": "cd apps/mobile && npx expo start",
    "build:web": "turbo run build --filter=./apps/web",
    "build:landing": "turbo run build --filter=landing",
    "build:all": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "supabase:functions:deploy": "supabase functions deploy --project-ref $SUPABASE_PROJECT_ID",
    "gen:types": "supabase gen types typescript --project-id kneaniaifzgqibpajyji > apps/web/src/types/supabase.ts"
  },
  "devDependencies": {
    "turbo": "^2",
    "supabase": "^2.76.15"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.0.0"
}
