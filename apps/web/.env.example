# ═══════════════════════════════════════════════════
# RXFin — Variáveis de Ambiente
# Atualizado: 2026-03-21
# ═══════════════════════════════════════════════════
# Copie para .env.local e preencha os valores reais.
# NUNCA commite .env.local.
# ═══════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────
VITE_SUPABASE_URL=https://kneaniaifzgqibpajyji.supabase.co
VITE_SUPABASE_ANON_KEY=COLOQUE_SUA_ANON_KEY_AQUI

# ── SEO / Canonical URL ───────────────────────────
# app = app.rxfin.com.br (não usar rxfin.com.br — é a landing)
VITE_CANONICAL_BASE=https://app.rxfin.com.br

# ── Logos de empresas (opcional) ──────────────────
# VITE_LOGODEV_TOKEN=seu_token_aqui

# ── NUNCA coloque service role key no client ──────
# SUPABASE_SERVICE_ROLE_KEY=NUNCA_AQUI

# ── Edge Functions (secrets no Dashboard Supabase, não no Vite) ──
# Parte B.1 PgBouncer: URI pooled (porta 6543, transaction mode)
# DATABASE_URL_POOLED=
# DATABASE_URL= (5432 — migrations / sessão)
# Parte B.4: réplica read-only (Postgres URI), apenas se usar SQL direto na Edge
# SUPABASE_DB_READER_URL=
