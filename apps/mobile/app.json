{
  "expo": {
    "name": "RXFin",
    "slug": "rxfin",
    "version": "1.1.0",
    "scheme": "rxfin",
    "orientation": "portrait",
    "icon": "./assets/logo-icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a7a4a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rxfin.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-icon.png",
        "backgroundColor": "#1a7a4a"
      },
      "package": "com.rxfin.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/logo-icon.png",
          "color": "#1a7a4a"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2192cc50-eba4-4b68-b7e9-5db287069a07"
      }
    },
    "owner": "rxfin"
  }
}
